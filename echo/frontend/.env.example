# Echo — frontend environment

# Backend API base URL (Django REST).
# In dev, leave empty and rely on MSW mocks. In prod / staging, set the URL of your Django server.
VITE_API_BASE_URL=

# WebSocket endpoint for real-time features (chat, presence, etc.).
# Used by useWebSocket(); the hook no-ops if this is empty.
VITE_WS_URL=

# OAuth — providers are stubbed on the front end. Set these to enable real redirects.
# Leave empty in dev (button is rendered but does a no-op; logs intent).
VITE_OAUTH_GOOGLE_CLIENT_ID=
VITE_OAUTH_GITHUB_CLIENT_ID=

# Set to "true" to force-enable MSW even outside dev. Useful for Storybook, demos, offline.
VITE_ENABLE_MOCKS=true

# Set to "true" to enable React Router future flags (v7 behavior).
VITE_ROUTER_FUTURE=true
